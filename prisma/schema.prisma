generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  DONOR
  CANDIDATE
  PAC
  ADMIN
}

enum OrganizationType {
  CANDIDATE
  PAC
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String
  fullName       String
  accountType    AccountType      @default(DONOR)
  donorProfile   DonorProfile?
  candidateProfile CandidateProfile?
  pacProfile     PacProfile?
  adminProfile   AdminProfile?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  accounts       Account[]
  sessions       Session[]
  donations      Donation[]       @relation("DonorDonations")
}

model Account {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  accessToken        String?
  refreshToken       String?
  tokenType          String?
  scope              String?
  expiresAt          Int?
  sessionState       String?
  user               User     @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DonorProfile {
  id              String    @id @default(cuid())
  user            User      @relation(fields: [userId], references: [id])
  userId          String    @unique
  savedPaymentRef String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?
  phone           String?
  employment      EmploymentInfo?
  donations       Donation[]      @relation("DonorDonations")
}

model EmploymentInfo {
  id             String       @id @default(cuid())
  donorProfile   DonorProfile @relation(fields: [donorProfileId], references: [id])
  donorProfileId String       @unique
  employer       String
  occupation     String
}

model CandidateProfile {
  id                  String             @id @default(cuid())
  user                User               @relation(fields: [userId], references: [id])
  userId              String             @unique
  organizationName    String
  office              String
  state               String
  district            String?
  stripeAccountId     String?
  applicationStatus   ApplicationStatus  @default(PENDING)
  onboardingCompleted Boolean            @default(false)
  programs            ProgramEnrollment[]
  donations           Donation[]         @relation("CandidateDonations")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model PacProfile {
  id                  String             @id @default(cuid())
  user                User               @relation(fields: [userId], references: [id])
  userId              String             @unique
  organizationName    String
  committeeId         String
  stripeAccountId     String?
  applicationStatus   ApplicationStatus  @default(PENDING)
  onboardingCompleted Boolean            @default(false)
  donations           Donation[]         @relation("PacDonations")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model AdminProfile {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  role      String   @default("standard")
  createdAt DateTime @default(now())
}

model Donation {
  id                  String      @id @default(cuid())
  amount              Int
  processingFeeAmount Int
  netAmount           Int
  donorId             String
  donor               DonorProfile @relation("DonorDonations", fields: [donorId], references: [id])
  recipientType       OrganizationType
  candidateId         String?
  candidate           CandidateProfile? @relation("CandidateDonations", fields: [candidateId], references: [id])
  pacId               String?
  pac                 PacProfile? @relation("PacDonations", fields: [pacId], references: [id])
  stripePaymentIntent String
  status              String
  createdAt           DateTime    @default(now())
}

model ProgramEnrollment {
  id                String            @id @default(cuid())
  candidateProfile  CandidateProfile  @relation(fields: [candidateProfileId], references: [id])
  candidateProfileId String
  program            String
  metadata           Json?
  createdAt          DateTime         @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}
